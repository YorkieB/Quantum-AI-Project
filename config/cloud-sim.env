# Jarvis Quantum — Cloud GPU Simulator Configuration (Tier 2)
# Uses PennyLane lightning.gpu on AWS EC2 or Braket Hybrid Jobs.
# Migrate here when local CPU simulation becomes too slow (>25 qubits).

JARVIS_COMPUTE_TIER=cloud-gpu

# Amazon Braket S3 bucket for results
BRAKET_S3_BUCKET=jarvis-quantum-results

# AWS credentials (set via AWS CLI or IAM role)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
